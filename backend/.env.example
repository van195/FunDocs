# Django
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS (frontend origin)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60

# Media uploads
MEDIA_ROOT=media

# Chapa
CHAPA_PUBLIC_KEY=replace-me
CHAPA_SECRET_KEY=replace-me
CHAPA_BASE_URL=https://api.chapa.co/v1/transaction/initialize
CHAPA_CALLBACK_URL=http://localhost:8000/api/payments/chapa/callback/
CHAPA_RETURN_URL=http://localhost:5173/
CHAPA_AMOUNT=10
CHAPA_CURRENCY=USD

# Groq (chat)
GROQ_API_KEY=replace-me
# See https://console.groq.com/docs/models — llama3-70b-8192 is decommissioned.
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Embeddings backend (for document search/RAG)
# Groq embeddings are often unavailable; default to local TF-IDF.
EMBEDDINGS_BACKEND=local  # local|groq
GROQ_EMBED_MODEL=nomic-embed-text-v1

